# 서버 설정
PORT=3000

# MQTT 브로커 주소 (RPi 로컬 Mosquitto)
MQTT_BROKER=mqtt://localhost:1883

# SQLite DB 경로
DB_PATH=./senibot.db

# Fitbit 시뮬레이터 시드 값 (실측치 기반)
FITBIT_SEED_HEART_RATE=
FITBIT_SEED_STEPS=
FITBIT_SEED_SLEEP_SCORE=
FITBIT_SEED_SPO2=

# 어르신 / 보호자 정보 (대시보드 표시용)
SENIOR_NAME=
GUARDIAN_NAME=
GUARDIAN_PHONE=

# 알림 엔진 임계값
TEMP_HIGH_THRESHOLD=35
TEMP_LOW_THRESHOLD=10
HUMID_HIGH_THRESHOLD=80
HUMID_LOW_THRESHOLD=20
HR_HIGH_THRESHOLD=100
HR_LOW_THRESHOLD=45
LOW_ACTIVITY_RATIO=0.3
ALERT_DEBOUNCE_SEC=300
